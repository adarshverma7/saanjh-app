<?xml version="1.0" encoding="utf-8"?>
<!--
  Saanjh Home Screen Widget — 2×4 (wide) layout.
  Displays: contact name, pulse time, streak count, record CTA.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@drawable/saanjh_widget_bg">

    <!-- Left: identity block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_wide_contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#F5EFE8"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_wide_pulse_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text=""
            android:textColor="#FF9500"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Right: streak + CTA -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end|center_vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/widget_wide_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 —"
            android:textColor="#FFA040"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_wide_cta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Record →"
            android:textColor="#FF9500"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</LinearLayout>
